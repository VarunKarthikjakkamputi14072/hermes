{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Hermes — Order Fulfillment Engine",
  "uid": "hermes-overview",
  "tags": ["hermes", "kafka", "orders"],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Order ingest rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"order-api\", uri=\"/api/orders\", method=\"POST\"}[1m]))",
          "legendFormat": "accepted /s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer lag (orders.placed)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"fulfilment-workers\", topic=\"orders.placed\"})",
          "legendFormat": "total lag",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Fulfilment outcomes (orders/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
          "expr": "sum by (result) (rate(hermes_orders_processed_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total orders processed",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
          "expr": "sum(hermes_orders_processed_total)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "End-to-end p99 (consumer poll → commit)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "hermes-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(spring_kafka_listener_seconds_bucket{application=\"fulfillment-worker\"}[1m])) by (le))",
          "refId": "A"
        }
      ]
    }
  ]
}
